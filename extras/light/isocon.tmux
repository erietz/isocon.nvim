# Isocon Light theme for tmux

set -g status-style "bg=#fdf6e3,fg=#8f8f8f"
set -g message-style "bg=#e9e2cf,fg=#8f8f8f"
set -g message-command-style "bg=#e9e2cf,fg=#8f8f8f"
set -g mode-style "bg=#e9e2cf,fg=#8f8f8f"
set -g pane-border-style "fg=#f6efdc"
set -g pane-active-border-style "fg=#5c8fe4"
set -g window-status-current-style "fg=#5c8fe4,bold"
set -g window-status-style "fg=#8f8f8f"

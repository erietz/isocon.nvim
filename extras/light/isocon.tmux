# Isocon Light theme for tmux

set -g status-style "bg=#fdf6e3,fg=#cbcbcb"
set -g message-style "bg=#f2dce1,fg=#8f8f8f"
set -g message-command-style "bg=#f2dce1,fg=#8f8f8f"
set -g mode-style "bg=#f2dce1,fg=#8f8f8f"
set -g pane-border-style "fg=#ffe9ee"
set -g pane-active-border-style "fg=#5c8fe4"
set -g window-status-current-style "fg=#8f8f8f,bold"
set -g window-status-style "fg=#cbcbcb"

# Isocon Dark theme for tmux

set -g status-style "bg=#282c34,fg=#686868"
set -g message-style "bg=#1c4050,fg=#9a9a9a"
set -g message-command-style "bg=#1c4050,fg=#9a9a9a"
set -g mode-style "bg=#1c4050,fg=#9a9a9a"
set -g pane-border-style "fg=#23333f"
set -g pane-active-border-style "fg=#6e9be7"
set -g window-status-current-style "fg=#9a9a9a,bold"
set -g window-status-style "fg=#686868"

# Isocon Dark theme for tmux

set -g status-style "bg=#282c34,fg=#9a9a9a"
set -g message-style "bg=#373b44,fg=#9a9a9a"
set -g message-command-style "bg=#373b44,fg=#9a9a9a"
set -g mode-style "bg=#9a9a9a,fg=#282c34"
set -g pane-border-style "fg=#2d3139"
set -g pane-active-border-style "fg=#6e9be7"
set -g window-status-current-style "fg=#6e9be7,bold"
set -g window-status-style "fg=#9a9a9a"
